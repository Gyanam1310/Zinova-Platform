# Google Sheets
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_SHEET_ID=your_sheet_id_here

# Brevo SMTP
# Login: your Brevo account email (e.g. you@gmail.com)
# Key:   Brevo dashboard → SMTP & API → SMTP → Generate SMTP key
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=your_brevo_account_email@example.com
BREVO_SMTP_KEY=your_brevo_smtp_key_here
BREVO_FROM_EMAIL=your_brevo_account_email@example.com
