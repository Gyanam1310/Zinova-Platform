# Backend Environment Variables

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-min-32-chars

# Brevo SMTP Configuration
BREVO_SMTP_SERVER=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_EMAIL=your-brevo-email@example.com
BREVO_PASSWORD=your-brevo-password
BREVO_SENDER_EMAIL=noreply@zinova.com

# Google Sheets Configuration
# The Google Spreadsheet ID where registrations will be stored
GOOGLE_SPREADSHEET_ID=your-google-spreadsheet-id

# Path to Google Service Account JSON credentials file
# Default: relative to project root (service-account.json)
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
